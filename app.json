{
  "expo": {
    "name": "Drop",
    "slug": "badmin",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "badmin",
    "userInterfaceStyle": "light",
    "description": "DGIST 배드민턴 동아리 Drop — 코트 예약·출석·매칭·포인트·레슨",
    "primaryColor": "#1B4332",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "kr.ac.dgist.badmin",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "체육관 현장 인증을 위해 위치 정보가 필요합니다.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "체육관 현장 인증을 위해 위치 정보가 필요합니다.",
        "CFBundleDisplayName": "Drop"
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1B4332",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "package": "kr.ac.dgist.badmin",
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.VIBRATE",
        "android.permission.POST_NOTIFICATIONS"
      ],
      "label": "Drop",
      "softwareKeyboardLayoutMode": "resize"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png",
      "name": "Drop",
      "shortName": "Drop",
      "description": "DGIST 배드민턴 동아리 Drop — 코트 예약·출석·매칭·포인트",
      "themeColor": "#1B4332",
      "backgroundColor": "#F3F8F6",
      "display": "standalone",
      "startUrl": "/",
      "lang": "ko"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#1B4332",
          "imageWidth": 200
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "체육관 현장 인증(500m 이내)을 위해 위치 정보가 필요합니다."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "프로필 사진을 설정하기 위해 사진 접근이 필요합니다.",
          "cameraPermission": "프로필 사진 촬영을 위해 카메라 접근이 필요합니다."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/notification-icon.png",
          "color": "#1B4332",
          "defaultChannel": "default"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "a173d24a-3169-4ff4-a552-889d9ac40f80"
      }
    },
    "owner": "go_pro"
  }
}
